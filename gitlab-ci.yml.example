# .gitlab-ci.yml — build Docker image, (optional) deploy via docker compose.
# Rename to .gitlab-ci.yml in the Python repo root.

stages:
  - build
  - deploy

variables:
  IMAGE: $CI_REGISTRY_IMAGE:$CI_COMMIT_SHORT_SHA

build:
  stage: build
  image: docker:27
  services:
    - docker:27-dind
  before_script:
    - docker login -u "$CI_REGISTRY_USER" -p "$CI_REGISTRY_PASSWORD" "$CI_REGISTRY"
  script:
    - docker build -t "$IMAGE" .
    - docker push "$IMAGE"
  only:
    - main
    - dev

deploy:
  stage: deploy
  image: alpine:3
  before_script:
    - apk add --no-cache openssh-client
    - eval $(ssh-agent -s)
    - echo "$DEPLOY_SSH_KEY" | ssh-add -
  script:
    - ssh -o StrictHostKeyChecking=no $DEPLOY_USER@$DEPLOY_HOST "
        cd /opt/hour_by_project &&
        git pull &&
        docker compose pull &&
        docker compose up -d --build"
  only:
    - main
  when: manual
